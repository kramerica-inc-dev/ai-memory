# Profile: OpenAI extraction + Gemini embedder (a common production default).
# Provider selection only — no secrets. Keys live in .env on the host.
# Activate:  ./memctl.sh switch openai-cloud
LLM_PROVIDER=openai
MODEL_NAME=gpt-5.4-mini
OPENAI_API_URL=https://api.openai.com/v1
EMBEDDER_PROVIDER=gemini
EMBEDDER_MODEL=gemini-embedding-001
EMBEDDER_DIMENSIONS=768
SEMAPHORE_LIMIT=12

# Profile: Gemini extraction LLM + Gemini embedder (single-vendor Google).
# Requires GOOGLE_API_KEY in .env. The reranker stays OpenAI (OPENAI_API_KEY required).
# Activate:  ./memctl.sh switch gemini
LLM_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash
EMBEDDER_PROVIDER=gemini
EMBEDDER_MODEL=gemini-embedding-001
EMBEDDER_DIMENSIONS=768
SEMAPHORE_LIMIT=8

# Profile: Claude Haiku 4.5 (Anthropic) as the extraction LLM — the budget route (~3× cheaper
# per token than Sonnet) for mass-ingest/backfill. Same embedder (local bge-m3 via infinity,
# same vector space) → hot-switchable with claude.env, no reindex. Requires ANTHROPIC_API_KEY
# in .env. Rationale: extraction does not need deep reasoning (see config.yaml); coarser
# entity-dedup can be corrected in place afterwards with `memctl dedup`.
# Activate:  ./memctl.sh switch haiku
LLM_PROVIDER=anthropic
MODEL_NAME=claude-haiku-4-5-20251001
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDER_DIMENSIONS=1024
EMBEDDER_OPENAI_URL=http://infinity:7997
EMBEDDER_OPENAI_KEY=local
# 12->4 (2026-07-11): 12 parallel coroutines also means 12 concurrent dedup searches
# (vec.cosineDistance without a vector index = full scan per entity) hammering the DB —
# on a small host that saturates the CPU, queries exceed TIMEOUT_DEFAULT and the queue
# enters a timed-out/retry loop. The dedup phase is DB-bound, not LLM-bound: keep this low.
SEMAPHORE_LIMIT=4

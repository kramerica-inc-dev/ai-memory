# Profile: Claude (Anthropic) as the extraction LLM. Embedder unchanged (Gemini/768) -> no reindex.
# Requires ANTHROPIC_API_KEY in .env. OPENAI_API_URL is deliberately NOT set: the reranker stays OpenAI.
# Activate:  ./memctl.sh switch claude
LLM_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-5
EMBEDDER_PROVIDER=gemini
EMBEDDER_MODEL=gemini-embedding-001
EMBEDDER_DIMENSIONS=768
SEMAPHORE_LIMIT=12

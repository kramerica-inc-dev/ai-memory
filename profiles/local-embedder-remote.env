# Profile: bge-m3 embeddings on a SECOND machine (e.g. one with a GPU), reached over a reverse
# tunnel — for when that machine is faster than the memory host but accepts no inbound
# connections (NAT/firewall). The second machine runs infinity + a tunnel CLIENT that dials out
# to a tunnel SERVER on the memory host; that forwards host:7997 -> infinity. graphiti therefore
# reaches the embedder on the memory host's docker-bridge gateway (172.18.0.1 is the common default).
#
# Same model as local-embedder (host) -> same vector space -> swappable with `switch --force`,
# NO reindex. NOTE: depends on the second machine being awake + the tunnel up. Meant for
# bulk/turbo, not as an always-on default. See docs/DEPLOY.md.
LLM_PROVIDER=openai
MODEL_NAME=gpt-5.4-mini
OPENAI_API_URL=https://api.openai.com/v1
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDER_DIMENSIONS=1024
EMBEDDER_OPENAI_URL=http://172.18.0.1:7997
EMBEDDER_OPENAI_KEY=local
SEMAPHORE_LIMIT=8

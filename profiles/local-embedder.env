# Profile: local, vendor-free embedder — BAAI/bge-m3 (multilingual, 1024 dims) via the
# infinity container (OpenAI-compatible /v1/embeddings). Extraction stays OpenAI (gpt-5.4-mini);
# only the embeddings go local — no gateway needed (the embedder gets its own base_url).
#
# NOTE — DIMENSION CHANGE 768 -> 1024: this requires a FULL reindex (wipe all graphs +
# re-embed). Never via `memctl switch` (it refuses an embedder change); always via:
#     ./memctl.sh reindex --to local-embedder
#
# Requires the infinity service to be running (docker-compose.yml) with bge-m3 loaded.
LLM_PROVIDER=openai
MODEL_NAME=gpt-5.4-mini
OPENAI_API_URL=https://api.openai.com/v1
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDER_DIMENSIONS=1024
EMBEDDER_OPENAI_URL=http://infinity:7997
EMBEDDER_OPENAI_KEY=local
SEMAPHORE_LIMIT=8

# ── AI memory: environment ──  Copy to .env and fill in. NEVER commit .env.

# Extraction LLM + embedder. This example uses Gemini for both (the default profile uses
# a Gemini embedder). Set the key(s) for whichever provider(s) you enable via profiles/.
GOOGLE_API_KEY=
# OPENAI_API_KEY=            # needed for OpenAI extraction AND the reranker (see docs/DEPLOY.md)
# ANTHROPIC_API_KEY=         # needed only for the Claude profile

MODEL_NAME=gemini-2.5-flash
EMBEDDER_MODEL=gemini-embedding-001
EMBEDDER_DIMENSIONS=768
# GOOGLE_PROJECT_ID=
# GOOGLE_LOCATION=us-central1

# FalkorDB
FALKORDB_PASSWORD=            # use a strong password even though the port is not published
FALKORDB_DATABASE=default_db
# Pin the image to a digest after the first pull:  docker images --digests | grep falkordb
FALKORDB_IMAGE=falkordb/falkordb:latest
# Data files (bind mount). On a server e.g. /opt/ai-memory/data/falkordb
FALKORDB_DATA=./data/falkordb

# Concurrency — keep it under your slowest provider's rate limit (raise carefully).
SEMAPHORE_LIMIT=8

# Bind address for port 8000. Keep 0.0.0.0 on a private tailnet; otherwise 127.0.0.1.
MCP_BIND=0.0.0.0

GRAPHITI_TELEMETRY_ENABLED=false

# Hygiene gate — URL of your secret-sanitizer (POST /api/sanitize), used client-side by the
# migration/capture scripts (NOT by the MCP server). If you proxy an external sanitizer via
# this host's Caddy (see Caddyfile :8080), point here at that proxy URL. Leave unset and pass
# --no-sanitize to the ingest scripts only for throwaway tests.
# SANITIZER_URL=http://your-memory-host:8080

# ── Fully-local alternative (Ollama instead of a cloud LLM) ──
# Then set llm.provider to "openai" via profiles/local-ollama.env and use:
# OPENAI_API_KEY=ollama
# OPENAI_API_URL=http://host.docker.internal:11434/v1
# MODEL_NAME=qwen2.5:14b
